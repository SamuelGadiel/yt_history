# YouTube Web Client API Key
# How to get it:
# 1. Open youtube.com in your browser
# 2. Open DevTools (F12) > Network tab
# 3. Filter by "youtubei"
# 4. Play a video or browse to trigger requests
# 5. Look for requests to "youtubei/v1/..."
# 6. Check URL parameters: key=AIzaSy...
# 7. Copy that key and paste below
#
# Note: This is YouTube's public web client key (same for all users)
# It's used to identify the client type, not for user authentication
YOUTUBE_API_KEY=your_api_key_here

# ============================================================================
# Locale Settings (Language & Region) - OPTIONAL
# ============================================================================
# Controls timestamp language ("Today" vs "Hoje" vs "Hoy", etc.)
# If empty, YouTube defaults to English.
#
# Format:
#   YOUTUBE_LANGUAGE: BCP 47 language tag (e.g., en-US, pt-BR, es-ES, de-DE)
#                     https://en.wikipedia.org/wiki/IETF_language_tag
#
#   YOUTUBE_REGION: ISO 3166-1 alpha-2 country code (e.g., US, BR, ES, DE)
#                   https://en.wikipedia.org/wiki/ISO_3166-1_alpha-2
#
# Examples:
#   en-US / US    English (US)        →  "Today", "Yesterday"
#   pt-BR / BR    Portuguese (BR)     →  "Hoje", "Ontem"
#   es-ES / ES    Spanish (Spain)     →  "Hoy", "Ayer"
#   de-DE / DE    German              →  "Heute", "Gestern"
#   ja-JP / JP    Japanese            →  "今日", "昨日"
#
YOUTUBE_LANGUAGE=
YOUTUBE_REGION=
